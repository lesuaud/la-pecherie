---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "La Pêcherie – Bistrot poisson & viande | Port d'Hourtin, Gironde",
  description = "Restaurant La Pêcherie au port d'Hourtin en Gironde. Spécialités moules, fruits de mer, poissons frais et viandes. Ouvert d'avril à octobre. Réservation : 07 50 36 56 46."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="restaurant port Hourtin, moules Hourtin, fruits de mer Gironde, bistrot bord lac, Médoc restaurant, La Pêcherie Hourtin, restaurant poisson Gironde" />
  <meta name="author" content="La Pêcherie" />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="restaurant" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://la-pecherie.netlify.app/" />
  <meta property="og:image" content="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1200&q=80" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="La Pêcherie" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1200&q=80" />

  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://la-pecherie.netlify.app/" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            cyan: { DEFAULT: '#10A0D0', light: '#90D0F0' },
            navy: { DEFAULT: '#0B3C5D', dark: '#07294A' },
            sand: '#F6EEE0',
            coral: '#E2603F',
          },
          fontFamily: {
            serif: ['Playfair Display', 'Georgia', 'serif'],
            sans: ['Inter', 'system-ui', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": "La Pêcherie",
    "description": "Bistrot poisson & viande au port d'Hourtin, Gironde. Spécialités moules, fruits de mer, poissons frais.",
    "url": "https://la-pecherie.netlify.app/",
    "telephone": "+33750365646",
    "email": "reservation.lapecherie.hourtin@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Port d'Hourtin, face au port, sous la résidence Odalys",
      "addressLocality": "Hourtin",
      "postalCode": "33990",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 45.18180,
      "longitude": -1.08516
    },
    "servesCuisine": ["Seafood", "French", "Fish"],
    "priceRange": "€€",
    "openingHours": [
      "Mo,Tu,Th,Fr,Sa,Su 12:00-14:30",
      "Mo,Th,Fr,Sa,Su 19:00-22:00"
    ],
    "image": "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1200&q=80",
    "hasMap": "https://maps.google.com/maps?q=45.18180,-1.08516"
  }
  </script>

  <style>
    html { scroll-behavior: smooth; }
    * { box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; }
    h1, h2, h3, .font-serif { font-family: 'Playfair Display', Georgia, serif; }
  </style>
</head>
<body class="bg-white text-gray-800 antialiased">
  <slot />
</body>
</html>
