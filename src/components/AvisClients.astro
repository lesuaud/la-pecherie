---
// ⚠️ Ces avis sont saisis manuellement — ils ne se mettent pas à jour automatiquement.
// Penser à les renouveler de temps en temps avec de nouveaux avis Google récents.
const avis = [
  {
    auteur: "Léo",
    texte: "Très belle découverte ! La Pêcherie propose des plats frais et savoureux, avec une excellente qualité de produits. Le service était chaleureux et attentionné. L'ambiance est agréable et conviviale, idéale pour passer un bon moment en famille ou entre amis. Je recommande sans hésiter, nous reviendrons avec plaisir !",
    etoiles: 5,
  },
  {
    auteur: "Domi Lavaux",
    texte: "Bien accueilli, moules excellentes, très bon rapport qualité-prix. Accueil chaleureux et convivial. Bel établissement très propre et vue sur le port. Je le recommande sans souci.",
    etoiles: 5,
  },
  {
    auteur: "Annie Coudert",
    texte: "Établissement situé face au port d'Hourtin, très bon accueil avec serveur très sympathique, rapport qualité-prix excellent. Tenue de l'établissement très propre. À recommander pour passer un agréable moment sans hésitation.",
    etoiles: 5,
  },
];
---

<section id="avis-clients" style="background-color: #0B3C5D;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="text-center mb-10">
      <span class="inline-block bg-[#10A0D0] text-white text-xs font-semibold uppercase tracking-widest px-4 py-1 rounded-full mb-4">Avis Google</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: 'Playfair Display', Georgia, serif;">
        Ce que disent nos clients
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {avis.map(a => (
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 flex flex-col gap-4">
          <!-- Étoiles -->
          <div class="flex gap-1" aria-label="5 étoiles sur 5">
            {Array.from({ length: a.etoiles }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#F5A623" class="w-5 h-5" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Texte -->
          <p class="text-white/90 text-sm leading-relaxed flex-1">
            &ldquo;{a.texte}&rdquo;
          </p>

          <!-- Auteur -->
          <div class="flex items-center justify-between pt-2 border-t border-white/20">
            <span class="text-white font-semibold text-sm">{a.auteur}</span>
            <span class="flex items-center gap-1.5 text-[#90D0F0] text-xs font-medium">
              <!-- Google "G" icon -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4" aria-hidden="true">
                <path fill="#EA4335" d="M5.266 9.765A7.077 7.077 0 0 1 12 4.909c1.69 0 3.218.6 4.418 1.582L19.91 3C17.782 1.145 15.055 0 12 0 7.27 0 3.198 2.698 1.24 6.65l4.026 3.115Z"/>
                <path fill="#34A853" d="M16.04 18.013c-1.09.703-2.474 1.078-4.04 1.078a7.077 7.077 0 0 1-6.723-4.823l-4.04 3.067A11.965 11.965 0 0 0 12 24c2.933 0 5.735-1.043 7.834-3l-3.793-2.987Z"/>
                <path fill="#4A90E2" d="M19.834 21c2.195-2.048 3.62-5.096 3.62-9 0-.71-.109-1.473-.272-2.182H12v4.637h6.436c-.317 1.559-1.17 2.766-2.395 3.558L19.834 21Z"/>
                <path fill="#FBBC05" d="M5.277 14.268A7.12 7.12 0 0 1 4.909 12c0-.782.125-1.533.357-2.235L1.24 6.65A11.934 11.934 0 0 0 0 12c0 1.92.445 3.73 1.237 5.335l4.04-3.067Z"/>
              </svg>
              Avis Google
            </span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
