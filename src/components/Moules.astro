---
import menu from '../data/menu.json';
const moulesSection = menu.sections.find(s => s.id === 'moules');
const highlighted = moulesSection?.items.filter(i => i.nom !== 'Supplément frites').slice(0, 4) || [];
---
<section id="moules" style="background-color: #0B3C5D;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block bg-[#10A0D0] text-white text-xs font-semibold uppercase tracking-widest px-4 py-1 rounded-full mb-4">Notre Spécialité</span>
      <h2 class="text-4xl sm:text-5xl font-bold text-white" style="font-family: 'Playfair Display', Georgia, serif;">Nos Moules</h2>
      <p class="text-[#90D0F0] mt-3 text-lg" style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;">Servies avec du pain du Fournil du Port et des frites dorées</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {highlighted.map(item => (
          <div class="rounded-xl p-5 relative" style="background-color: #0e4a72;">
            <span class="absolute top-4 right-4 bg-[#E2603F] text-white text-xs font-bold px-2 py-1 rounded-full">{item.prix}</span>
            <h3 class="text-white font-semibold text-base pr-16 mb-1" style="font-family: 'Playfair Display', Georgia, serif;">{item.nom}</h3>
            {item.description && <p class="text-[#90D0F0] text-sm">{item.description}</p>}
          </div>
        ))}
      </div>

      <!-- Photo placeholder + CTA -->
      <div class="flex flex-col gap-6">
        <!-- [À REMPLACER - photo de moules du restaurant] -->
        <div class="relative rounded-2xl overflow-hidden h-72 lg:h-96">
          <img
            src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=800&q=80"
            alt="Moules marinière — Brasserie La Pêcherie, port d'Hourtin (Gironde)"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(11,60,93,0.6) 0%, transparent 50%);"></div>
        </div>
        <div class="text-center">
          <p class="text-[#90D0F0] mb-4 text-sm">Et bien d'autres plats vous attendent sur notre carte…</p>
          <a
            href="/carte"
            class="inline-block border-2 border-[#10A0D0] text-[#10A0D0] hover:bg-[#10A0D0] hover:text-white font-semibold px-6 py-3 rounded-full text-sm transition-all duration-200"
          >
            Voir la carte complète →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
