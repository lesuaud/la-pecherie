---
import config from '../data/config.json';
import horaires from '../data/horaires.json';
---
<section id="infos" style="background-color: #F6EEE0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-14">
      <span class="inline-block bg-[#10A0D0] text-white text-xs font-semibold uppercase tracking-widest px-4 py-1 rounded-full mb-4">Nous Trouver</span>
      <h2 class="text-4xl sm:text-5xl font-bold text-[#0B3C5D]" style="font-family: 'Playfair Display', Georgia, serif;">Infos Pratiques</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: hours + contact -->
      <div class="space-y-8">
        <!-- Phone -->
        <div>
          <a
            href={config.contact.telephoneHref}
            class="inline-flex items-center gap-3 bg-[#E2603F] hover:bg-orange-600 text-white font-bold px-8 py-4 rounded-full text-xl transition-all duration-200 shadow-lg mb-3"
          >
            📞 {config.contact.telephone}
          </a>
          <p class="text-gray-600 text-sm">Réservation par téléphone recommandée en haute saison</p>
        </div>

        <!-- Hours -->
        <div class="bg-white rounded-2xl p-6 shadow-sm">
          <h3 class="text-xl font-bold text-[#0B3C5D] mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
            🕐 Horaires — {horaires.saison.debut} à {horaires.saison.fin}
          </h3>
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="py-2 pr-4 text-gray-600 font-medium">Déjeuner</td>
                <td class="py-2 text-[#0B3C5D] font-semibold">{horaires.service.midi}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2 pr-4 text-gray-600 font-medium">Dîner</td>
                <td class="py-2 text-[#0B3C5D] font-semibold">{horaires.service.soir}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2 pr-4 text-gray-600 font-medium">Juillet / Août</td>
                <td class="py-2 text-green-600 font-semibold">{horaires.fermetures.juilletAout}</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 text-gray-600 font-medium align-top">Hors juillet-août</td>
                <td class="py-2 text-[#0B3C5D] font-semibold">
                  Fermé le {horaires.fermetures.horsJuilletAout.join(' et le ')}
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Address -->
        <div class="bg-white rounded-2xl p-6 shadow-sm">
          <h3 class="text-xl font-bold text-[#0B3C5D] mb-3" style="font-family: 'Playfair Display', Georgia, serif;">📍 Adresse</h3>
          <p class="text-gray-700 text-sm leading-relaxed mb-1">{config.contact.adresse}</p>
          <p class="text-gray-700 text-sm">{config.contact.codePostal} {config.contact.ville}</p>
          <a
            href={config.contact.googleMapsLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-4 text-[#10A0D0] hover:text-[#0B3C5D] font-semibold text-sm transition-colors"
          >
            🗺️ Obtenir l'itinéraire →
          </a>
        </div>

        <!-- Email -->
        <div class="bg-white rounded-2xl p-6 shadow-sm">
          <h3 class="text-xl font-bold text-[#0B3C5D] mb-3" style="font-family: 'Playfair Display', Georgia, serif;">✉️ Email</h3>
          <a
            href={`mailto:${config.contact.emailResa}`}
            class="text-[#10A0D0] hover:underline text-sm break-all"
          >
            {config.contact.emailResa}
          </a>
        </div>
      </div>

      <!-- Right: Google Maps -->
      <div class="rounded-2xl overflow-hidden shadow-xl h-[500px]">
        <iframe
          src="https://maps.google.com/maps?q=45.18180,-1.08516&z=16&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="La Pêcherie - Port d'Hourtin sur Google Maps"
        ></iframe>
      </div>
    </div>
  </div>
</section>
